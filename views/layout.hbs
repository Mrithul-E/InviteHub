    crossorigin="anonymous"></script>

  <title>{{title}}</title>
</head>

<body>
  <nav class="navbar navbar-expand-lg">
    <div class="container-fluid">
      <a class="navbar-brand" href="#">
        <img src="/images/FullLogo_Transparent_NoBuffer.png" alt="Bootstrap" width="auto" height="60">
      </a>
      <div class="collapse navbar-collapse" id="navbarSupportedContent">
        <ul class="navbar-nav mx-auto mb-2 mb-lg-0">
          <li class="nav-item">
            <a class="nav-link active" aria-current="page" href="#">Home</a>
          </li>
          <li class="nav-item">
            <a class="nav-link" aria-current="page" href="#">Templates</a>
          </li>
          <li class="nav-item">
            <a class="nav-link" aria-current="page" href="#">Examples</a>
          </li>
          <li class="nav-item">
            <a class="nav-link" aria-current="page" href="#">About</a>
          </li>
          <li class="nav-item">
            <a class="nav-link" aria-current="page" href="#">GitHub</a>
          </li>
        </ul>
      </div>
      <div id="nav-end-container" class="d-flex">
        {{#if isLoggedIn}}
        <div id="userContainer" class="d-flex">
          <div class="d-flex">
            <img src="{{userRecord.photoURL}}" alt="user profile picture" width="40" height="40"
              class="me-2 rounded-circle" id="userPicture">
            <span class="material-symbols-outlined">
              keyboard_arrow_down
            </span>
          </div>
          <div id="userMenu" class="d-none">
            <h5>{{userRecord.displayName}}</h5>
            <button type="button" class="btn btn-danger" id="logout-btn">Logout</button>
          </div>
        </div>
        {{/if}}
        <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#navbarSupportedContent"
          aria-controls="navbarSupportedContent" aria-expanded="false" aria-label="Toggle navigation">
          <span class="navbar-toggler-icon"></span>
        </button>
      </div>
    </div>
  </nav>


  {{{body}}}

  <script type="module">
    // Import the functions you need from the SDKs you need
    import { initializeApp } from "https://www.gstatic.com/firebasejs/12.14.0/firebase-app.js";
    import { getAnalytics } from "https://www.gstatic.com/firebasejs/12.14.0/firebase-analytics.js";
    import { getAuth, GoogleAuthProvider, signInWithPopup } from "https://www.gstatic.com/firebasejs/12.14.0/firebase-auth.js";
    // TODO: Add SDKs for Firebase products that you want to use
    // https://firebase.google.com/docs/web/setup#available-libraries

    // Your web app's Firebase configuration
    // For Firebase JS SDK v7.20.0 and later, measurementId is optional
    const firebaseConfig = {
      apiKey: "AIzaSyDyVIsPK1zSZogVBbErB3_2-DKlovEDCjM",
      authDomain: "invitehub-3d733.firebaseapp.com",
      projectId: "invitehub-3d733",
      storageBucket: "invitehub-3d733.firebasestorage.app",
      messagingSenderId: "897414221009",
      appId: "1:897414221009:web:751cd7eb3060bf0c5dc9f0",
      measurementId: "G-7N1W087TM6"
    };

    // Initialize Firebase
    window.app = initializeApp(firebaseConfig);
    window.analytics = getAnalytics(app);

    window.auth = getAuth(app);
    window.googleProvider = new GoogleAuthProvider();
    window.firebaseSignIn = signInWithPopup;
  </script>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"
    integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI"
    crossorigin="anonymous"></script>

  <script>
    $(document).ready(function () {
      const logoutButton = $("#logout-btn")
      const profilePicture = $("#userPicture")
      const img = profilePicture[0];
      const userMenu = $("#userMenu")
      const userDisplayName = "{{userRecord.displayName}}" 

      if (userDisplayName) {
        const canvas = document.createElement('canvas')
        canvas.width = profilePicture.attr('width')
        canvas.height = profilePicture.attr('height')

        const ctx = canvas.getContext('2d')
        ctx.fillStyle = "#7C3D8A"

        ctx.fillRect(0,0 , canvas.width, canvas.height)

        ctx.fillStyle = 'white'
        ctx.font = "400 24px Poppins";
        ctx.textAlign = "center"
        ctx.textBaseline = "middle"

        const firstLetter = userDisplayName[0].toUpperCase()

        ctx.fillText(
          firstLetter, canvas.width/2, canvas.height/2 + 2
        )

        profilePicture[0].src = canvas.toDataURL("image/png")
      }

      logoutButton.click(function () {
        window.location.href = "/logout"
      })

      profilePicture.click(function () {
        userMenu.toggleClass('d-none')
      })
    })
  </script>
</body>

</html>