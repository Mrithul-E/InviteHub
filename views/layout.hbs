<!doctype html>
<html lang="en">

<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link
    href="https://fonts.googleapis.com/css2?family=Poppins:ital,wght@0,100;0,200;0,300;0,400;0,500;0,600;0,700;0,800;0,900;1,100;1,200;1,300;1,400;1,500;1,600;1,700;1,800;1,900&family=Source+Code+Pro:ital,wght@0,200..900;1,200..900&display=swap"
    rel="stylesheet">
  <link rel="stylesheet"
    href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@24,400,0,0&icon_names=keyboard_arrow_down" />
  <!-- Bootstrap Icons v1.13.1 CDN -->
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.css">
  <link rel="stylesheet" href="/stylesheets/style.css">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet"
    integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
  <script src="https://code.jquery.com/jquery-4.0.0.js" integrity="sha256-9fsHeVnKBvqh3FB2HYu7g2xseAZ5MlN6Kz/qnkASV8U="
    crossorigin="anonymous"></script>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"
    integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI"
    crossorigin="anonymous"></script>

  <title>{{title}}</title>
</head>

<body>
  <nav class="navbar navbar-expand-lg fixed-top">
    <div class="container-fluid">
      <a class="navbar-brand" href="#">
        <img src="/images/FullLogo_Transparent_NoBuffer.png" alt="Bootstrap" width="auto" height="60">
      </a>
      <div id="nav-end-container" class="d-flex">
        {{#if isLoggedIn}}
        <div id="userContainer" class="d-flex">
          <div class="d-flex align-items-center" id="userClickableContainer">
            <img src="{{userRecord.photoURL}}" alt="user profile picture" width="40" height="40"
              class="me-2 rounded-circle" id="userPicture">
            <span class="material-symbols-outlined user-select-none" id="userMenuDrownArrow">
              keyboard_arrow_down
            </span>
          </div>
          <div id="userMenu" class="d-none">
            <h5>{{#if adminLoggedIn}}ADMIN : {{/if}}{{userRecord.displayName}}</h5>
            <button type="button" class="btn btn-danger" id="logout-btn">Logout</button>
          </div>
        </div>
        {{/if}}
        <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#navbarSupportedContent"
          aria-controls="navbarSupportedContent" aria-expanded="false" aria-label="Toggle navigation">
          <span class="navbar-toggler-icon"></span>
        </button>
      </div>
      <div class="collapse navbar-collapse" id="navbarSupportedContent">
        <ul class="navbar-nav mx-auto mb-2 mb-lg-0" id="navbar-ul">
          <li class="nav-item">
            <a class="nav-link active" aria-current="page" href="/">Home</a>
          </li>
          <li class="nav-item">
            <a class="nav-link" aria-current="page" href="/templates">Templates</a>
          </li>
          <li class="nav-item">
            <a class="nav-link" aria-current="page" href="#">Examples</a>
          </li>
          <li class="nav-item">
            <a class="nav-link" aria-current="page" href="#">About</a>
          </li>
          <li class="nav-item">
            <a class="nav-link" aria-current="page" href="#">GitHub</a>
          </li>
        </ul>
      </div>
      
    </div>
  </nav>

  <main>
    {{{body}}}
  </main>
  
  <footer class="text-dark py-4 mt-auto" id="footer">
      <div class="container">
        <div class="row align-items-center">
          <div class="col-md-4 text-center text-md-start mb-3 mb-md-0">
            <img class="footer-brand" src="images/Logo_Transparent_NoBuffer.png" alt="InviteHub icon">
            <h5 class="mb-1 text-dark">InviteHub</h5>
            <p class="small mb-0 opacity-75">Reliable information for better health awareness.</p>
          </div>
          <div class="col-md-4 text-center mb-3 mb-md-0">
            <div class="mb-2">
              <a href="/about" class="text-dark mx-2 small text-decoration-none">About</a>
              <a href="/privacy-policy" class="text-dark mx-2 small text-decoration-none">Privacy</a>
              <a href="/terms" class="text-dark mx-2 small text-decoration-none">Terms</a>
              <a href="/contact" class="text-dark mx-2 small text-decoration-none">Contact</a>
            </div>
            <p class="small mb-0 opacity-75">Made with <i class="bi bi-heart-fill text-danger mx-1"></i> in India by
              <b>Mrithul</b>
            </p>
          </div>
          <div class="col-md-4 text-center text-md-end">
            <div class="fs-5">
              <a href="https://github.com/Mrithul-E" target="_blank" class="text-dark me-3 text-decoration-none"><i class="bi bi-github"></i></a>
              <a href="https://www.instagram.com/mrithull_" target="_blank" class="text-dark me-3 text-decoration-none"><i class="bi bi-instagram"></i></a>
              <a href="mailto:mrithul100@gmail.com" class="text-dark text-decoration-none"><i class="bi bi-envelope-at"></i></a>
            </div>
          </div>
        </div>
        <hr class="my-3 opacity-25">
        <div class="text-center small opacity-50">
          © 2026 InviteHub. All rights reserved.
        </div>
      </div>
    </footer>

  {{{firebaseClientCred}}}

  <script>
    function highlightCurrentPageLink() {
      const currentPageUrl = window.location.pathname

      const links = document.querySelectorAll("#navbar-ul li a")

      links.forEach((link)=>{
        const href = link.getAttribute("href")

        if (href.split("/")[1] === currentPageUrl.split("/")[1]) {
          link.classList.add("active")
        }else{
          link.classList.remove("active")
        }
      })
    }

    $(document).ready(function () {
      highlightCurrentPageLink();
      
      const logoutButton = $("#logout-btn")
      const profilePicture = $("#userPicture")
      const img = profilePicture[0];
      const userMenu = $("#userMenu")
      const userMenuDrownArrow = $('#userMenuDrownArrow')
      const userContainer = $("#userContainer")
      const userDisplayName = "{{userRecord.displayName}}"       

      if (userDisplayName && img.naturalWidth === 0) {
        const canvas = document.createElement('canvas')
        canvas.width = profilePicture.attr('width')
        canvas.height = profilePicture.attr('height')

        const ctx = canvas.getContext('2d')
        ctx.fillStyle = "#7C3D8A"

        ctx.fillRect(0,0 , canvas.width, canvas.height)

        ctx.fillStyle = 'white'
        ctx.font = "400 24px Poppins";
        ctx.textAlign = "center"
        ctx.textBaseline = "middle"

        const firstLetter = userDisplayName[0].toUpperCase()

        ctx.fillText(
          firstLetter, canvas.width/2, canvas.height/2 + 2
        )

        profilePicture[0].src = canvas.toDataURL("image/png")
      }

      logoutButton.click(function () {
        window.location.href = "/logout"
      })

      userContainer.click(function () {
        userMenu.toggleClass('d-none')
        if (userMenu.hasClass('d-none')) {
          userMenuDrownArrow.removeClass('rotate-180')
        }else{
          userMenuDrownArrow.addClass('rotate-180')
        }
      })

    })
  </script>
</body>

</html>